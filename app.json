{
  "expo": {
    "name": "CommunityPulse",
    "slug": "community-pulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "communitypulse",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3c72"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chikitella.communitypulse"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e3c72",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.chikitella.communitypulse",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY_HERE"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow CommunityPulse to use your location to attach GPS coordinates to issue reports."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow CommunityPulse to access your photos to attach images to issue reports."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "7c10d001-3023-43a7-8f64-a6c23bbd3787"
      }
    },
    "owner": "chikitella"
  }
}
